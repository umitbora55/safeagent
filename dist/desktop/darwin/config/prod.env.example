CONTROL_PLANE_ADDR=127.0.0.1:10443
CONTROL_PLANE_LISTEN_ADDR=127.0.0.1:10443
WORKER_ADDR=127.0.0.1:10280
MTLS_CA=/etc/safeagent/pki/ca.crt
MTLS_CERT=/etc/safeagent/pki/control-plane.crt
MTLS_KEY=/etc/safeagent/pki/control-plane.key
WORKER_MTLS_CA=/etc/safeagent/pki/ca.crt
WORKER_MTLS_CERT=/etc/safeagent/pki/worker.crt
WORKER_MTLS_KEY=/etc/safeagent/pki/worker.key

# Secret backend (vault preferred in prod)
CONTROL_PLANE_SECRET_BACKEND=vault
CONTROL_PLANE_SECRET_DIR=platform/control-plane/.secrets
CONTROL_PLANE_VAULT_ADDR=https://vault.internal:8200
CONTROL_PLANE_VAULT_TOKEN=replace-with-vault-token
CONTROL_PLANE_VAULT_MOUNT=kv
SAFEAGENT_SECRET_PASSWORD=unused

# Rate limiting defaults
CONTROL_PLANE_TENANT_CONCURRENT_LIMIT=20
CONTROL_PLANE_TENANT_QUEUE_LIMIT=200
CONTROL_PLANE_TENANT_TOKEN_BUCKET_CAPACITY=1000
CONTROL_PLANE_TENANT_TOKEN_BUCKET_REFILL_PER_SECOND=100
CONTROL_PLANE_TENANT_COST_BUDGET=200000

# JWKS cache / verification settings
WORKER_JWKS_TTL_SECONDS=30

LOG_LEVEL=warn
APPROVAL_TIMEOUT_SECONDS=15
