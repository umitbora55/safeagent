{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SafeAgent",
  "version": "0.1.0",
  "identifier": "com.safeagent.desktop",
  "build": {
    "frontendDist": "../desktop-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SafeAgent",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": true,
        "focus": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.anthropic.com ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "SafeAgent"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Secure AI assistant with enterprise-grade safety",
    "longDescription": "SafeAgent is an enterprise-grade AI safety platform that lets you interact with Claude AI securely. Your credentials are encrypted locally, your data never leaves your device, and every action is policy-controlled.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "exceptionDomain": "api.anthropic.com",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  }
}
