CONTROL_PLANE_ADDR=127.0.0.1:8443
CONTROL_PLANE_LISTEN_ADDR=127.0.0.1:8443
WORKER_ADDR=127.0.0.1:8280
MTLS_CA=platform/pki/ca.crt
MTLS_CERT=platform/pki/control-plane.crt
MTLS_KEY=platform/pki/control-plane.key
WORKER_MTLS_CA=platform/pki/ca.crt
WORKER_MTLS_CERT=platform/pki/worker.crt
WORKER_MTLS_KEY=platform/pki/worker.key

# Secret backend
CONTROL_PLANE_SECRET_BACKEND=file
CONTROL_PLANE_SECRET_DIR=platform/control-plane/.secrets
SAFEAGENT_SECRET_PASSWORD=change-me

# Rate limiting defaults (per-tenant)
CONTROL_PLANE_TENANT_CONCURRENT_LIMIT=5
CONTROL_PLANE_TENANT_QUEUE_LIMIT=20
CONTROL_PLANE_TENANT_TOKEN_BUCKET_CAPACITY=10000
CONTROL_PLANE_TENANT_TOKEN_BUCKET_REFILL_PER_SECOND=10000
CONTROL_PLANE_TENANT_COST_BUDGET=1000000

# JWKS cache / verification settings
WORKER_JWKS_TTL_SECONDS=60

LOG_LEVEL=info
APPROVAL_TIMEOUT_SECONDS=30
